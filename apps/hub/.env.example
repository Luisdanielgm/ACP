ACP_HOST=0.0.0.0
ACP_PORT=8000
ACP_ASGI_APP=acp_managed.app:app
ACP_PUBLIC_WEB_ENABLED=false
ACP_LEGACY_DASHBOARD_ENABLED=false
ACP_PERSISTENCE_BACKEND=sqlite
ACP_SQLITE_PATH=/data/acp/acp.sqlite3
ACP_MANAGED_AUTH_SQLITE_PATH=/data/acp/acp-managed-auth.sqlite3

# deployment mode
# public/default: single_workspace (one admin, one workspace)
# private/cloud: operator (multi-workspace operator surface)
ACP_DEPLOYMENT_MODE=single_workspace

# single-workspace bootstrap
# required for first boot in single_workspace mode
ACP_WORKSPACE_SLUG=default
ACP_WORKSPACE_NAME="My ACP Workspace"
ACP_WORKSPACE_ADMIN_EMAIL=
ACP_WORKSPACE_ADMIN_PASSWORD_HASH=

# managed browser login
# required: service startup rejects empty or placeholder secrets
ACP_MANAGED_SESSION_SECRET=
ACP_MANAGED_AGENT_TOKEN_SECRET=
ACP_MANAGED_SESSION_TTL_SECONDS=43200

# operator-mode initial whitelist entries
# format: email=password_hash:role,status;email2=password_hash:role,status
ACP_MANAGED_WHITELIST=

# optional legacy hub token for runtime/admin compatibility
ACP_TOKEN=
ACP_MAX_PAYLOAD_BYTES=32768
